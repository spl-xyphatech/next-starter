generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// USER MANAGEMENT
// ============================================================

model User {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(256)
  username    String    @unique @db.VarChar(256)
  email       String    @unique @db.VarChar(256)
  phone       String?
  password    String
  avatar      String?
  isFirstTime Boolean   @default(true) @map("is_first_time")
  createdBy   String?   @map("created_by")
  updatedBy   String?   @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  roleId      String    @map("role_id") @db.Uuid
  role        Role?     @relation(fields: [roleId], references: [id])

  customer Customer?
  merchant Merchant?

  @@index([name])
  @@index([email])
  @@map("users")
}

model Role {
  id             String           @id @default(uuid()) @db.Uuid
  code           String           @unique
  name           String
  description    String?
  createdBy      String?          @map("created_by")
  updatedBy      String?          @map("updated_by")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz(6)
  RolePermission RolePermission[]
  User           User[]

  @@index([name])
  @@map("roles")
}

model RolePermission {
  id           String      @id @default(uuid()) @db.Uuid
  roleId       String      @map("role_id") @db.Uuid
  permissionId String      @map("permission_id") @db.Uuid
  description  String?
  createdBy    String?     @map("created_by")
  updatedBy    String?     @map("updated_by")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)
  role         Role?       @relation(fields: [roleId], references: [id])
  permission   Permission? @relation(fields: [permissionId], references: [id])

  @@map("role_permissions")
}

model Permission {
  id             String           @id @default(uuid()) @db.Uuid
  module         String
  action         String
  description    String?
  createdBy      String?          @map("created_by")
  updatedBy      String?          @map("updated_by")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz(6)
  RolePermission RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

// ============================================================
// MERCHANT
// ============================================================

model Merchant {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @unique @map("user_id") @db.Uuid
  name           String         @db.VarChar(256)
  description    String?        @db.Text
  address        String?        @db.VarChar(512)
  phone          String?        @db.VarChar(20)
  status         MerchantStatus @default(PENDING)
  rejectedReason String?        @map("rejected_reason") @db.Text
  approvedAt     DateTime?      @map("approved_at") @db.Timestamptz(6)
  approvedBy     String?        @map("approved_by")
  createdBy      String?        @map("created_by")
  updatedBy      String?        @map("updated_by")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz(6)

  user               User               @relation(fields: [userId], references: [id])
  images             MerchantImage[]
  eventMerchants     EventMerchant[]
  eventRequests      EventRequest[]
  merchantCategories MerchantCategory[]
  merchantTags       MerchantTag[]

  @@index([name])
  @@index([status])
  @@map("merchants")
}

enum MerchantStatus {
  PENDING
  APPROVED
  REJECTED
}

model MerchantImage {
  id         String    @id @default(uuid()) @db.Uuid
  merchantId String    @map("merchant_id") @db.Uuid
  url        String    @db.VarChar(512)
  sortOrder  Int       @default(0) @map("sort_order")
  createdBy  String?   @map("created_by")
  updatedBy  String?   @map("updated_by")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@map("merchant_images")
}

// ============================================================
// CUSTOMER
// ============================================================

model Customer {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @unique @map("user_id") @db.Uuid
  socialProvider String?   @map("social_provider") @db.VarChar(50)
  socialId       String?   @map("social_id") @db.VarChar(256)
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  user            User             @relation(fields: [userId], references: [id])
  customerCoupons CustomerCoupon[]

  @@map("customers")
}

// ============================================================
// CATEGORY
// ============================================================

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique @db.VarChar(64)
  name        String    @db.VarChar(128)
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdBy   String?   @map("created_by")
  updatedBy   String?   @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  merchantCategories MerchantCategory[]

  @@index([name])
  @@map("categories")
}

// ============================================================
// TAG
// ============================================================

model Tag {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique @db.VarChar(64)
  name        String    @db.VarChar(128)
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdBy   String?   @map("created_by")
  updatedBy   String?   @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  merchantTags MerchantTag[]

  @@index([code])
  @@map("tags")
}

model MerchantCategory {
  id         String   @id @default(uuid()) @db.Uuid
  merchantId String   @map("merchant_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  merchant Merchant @relation(fields: [merchantId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([merchantId, categoryId])
  @@map("merchant_categories")
}

model MerchantTag {
  id         String   @id @default(uuid()) @db.Uuid
  merchantId String   @map("merchant_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  merchant Merchant @relation(fields: [merchantId], references: [id])
  tag      Tag      @relation(fields: [tagId], references: [id])

  @@unique([merchantId, tagId])
  @@map("merchant_tags")
}

// ============================================================
// EVENT & COUPON
// ============================================================

model Event {
  id           String      @id @default(uuid()) @db.Uuid
  title        String      @db.VarChar(256)
  description  String?     @db.Text
  totalQty     Int         @map("total_qty")
  claimedQty   Int         @default(0) @map("claimed_qty")
  perUserLimit Int         @default(1) @map("per_user_limit")
  startAt      DateTime    @map("start_at") @db.Timestamptz(6)
  expiredAt    DateTime    @map("expired_at") @db.Timestamptz(6)
  status       EventStatus @default(ACTIVE)
  isAdminEvent Boolean     @default(false) @map("is_admin_event")
  createdBy    String?     @map("created_by")
  updatedBy    String?     @map("updated_by")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)

  eventMerchants EventMerchant[]
  coupons        Coupon[]
  eventRequest   EventRequest?

  @@index([status])
  @@index([expiredAt])
  @@map("events")
}

enum EventStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

model EventMerchant {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  merchantId String   @map("merchant_id") @db.Uuid
  qtyLimit   Int?     @map("qty_limit")
  claimedQty Int      @default(0) @map("claimed_qty")
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event    Event    @relation(fields: [eventId], references: [id])
  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([eventId, merchantId])
  @@map("event_merchants")
}

model EventRequest {
  id           String             @id @default(uuid()) @db.Uuid
  merchantId   String             @map("merchant_id") @db.Uuid
  title        String             @db.VarChar(256)
  description  String?            @db.Text
  status       EventRequestStatus @default(PENDING)
  eventId      String?            @unique @map("event_id") @db.Uuid
  rejectedNote String?            @map("rejected_note") @db.Text
  reviewedAt   DateTime?          @map("reviewed_at") @db.Timestamptz(6)
  reviewedBy   String?            @map("reviewed_by")
  createdBy    String?            @map("created_by")
  updatedBy    String?            @map("updated_by")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?          @map("deleted_at") @db.Timestamptz(6)

  merchant Merchant @relation(fields: [merchantId], references: [id])
  event    Event?   @relation(fields: [eventId], references: [id])

  @@index([merchantId])
  @@index([status])
  @@map("event_requests")
}

enum EventRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Coupon {
  id        String       @id @default(uuid()) @db.Uuid
  uuid      String       @unique @default(uuid()) @db.Uuid
  eventId   String       @map("event_id") @db.Uuid
  status    CouponStatus @default(AVAILABLE)
  createdBy String?      @map("created_by")
  updatedBy String?      @map("updated_by")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz(6)

  event          Event           @relation(fields: [eventId], references: [id])
  customerCoupon CustomerCoupon?

  @@index([eventId])
  @@index([status])
  @@map("coupons")
}

enum CouponStatus {
  AVAILABLE
  CLAIMED
  REDEEMED
  EXPIRED
}

model CustomerCoupon {
  id         String    @id @default(uuid()) @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  couponId   String    @unique @map("coupon_id") @db.Uuid
  claimedAt  DateTime  @default(now()) @map("claimed_at") @db.Timestamptz(6)
  redeemedAt DateTime? @map("redeemed_at") @db.Timestamptz(6)
  redeemedBy String?   @map("redeemed_by") @db.Uuid
  createdBy  String?   @map("created_by")
  updatedBy  String?   @map("updated_by")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer Customer @relation(fields: [customerId], references: [id])
  coupon   Coupon   @relation(fields: [couponId], references: [id])

  @@unique([customerId, couponId])
  @@index([customerId])
  @@map("customer_coupons")
}
